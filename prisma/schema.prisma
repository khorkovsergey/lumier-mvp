generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Identity ──────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique
  passwordHash String?
  role         UserRole  @default(CLIENT)
  dateOfBirth  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  questions      Question[]
  sessions       Session[]
  orders         Order[]
  readerProfile  TarotReader?
  articles       InsightArticle[]
  tarotReadings  TarotReadingRecord[]
}

enum UserRole {
  CLIENT
  READER
  ADMIN
}

// ─── Reader profile ───────────────────────────────────────────────────────────

model TarotReader {
  id             String     @id @default(cuid())
  userId         String     @unique
  name           String
  specialization String
  tier           ReaderTier
  price          Float
  rating         Float      @default(5.0)
  bio            String
  imageUrl       String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Question {
  id        String   @id @default(cuid())
  userId    String
  text      String
  category  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String        @id @default(cuid())
  userId    String
  readerId  String
  type      SessionType
  status    SessionStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  reader       TarotReader  @relation(fields: [readerId], references: [id])
  order        Order?
  asyncReading AsyncReading?
  messages     Message[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  sessionId String      @unique
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}

model AsyncReading {
  id          String             @id @default(cuid())
  sessionId   String             @unique
  status      AsyncReadingStatus @default(PENDING)
  resultText  String?
  draftText   String?
  createdAt   DateTime           @default(now())
  completedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id])
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  senderType SenderType
  content    String
  type       MessageType @default(TEXT)
  createdAt  DateTime    @default(now())

  session Session @relation(fields: [sessionId], references: [id])
}

model InsightArticle {
  id        String   @id @default(cuid())
  title     String
  preview   String
  content   String
  category  String   @default("general")
  readTime  Int      @default(5)
  published Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── AI Tarot Readings ────────────────────────────────────────────────────────

model TarotReadingRecord {
  id             String   @id @default(cuid())
  userId         String
  question       String
  category       String   @default("general")
  cardsJson      String   // JSON array of drawn cards
  summary        String
  interpretation String
  cardsInsight   String   // JSON array of per-card insights
  advice         String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReaderTier {
  FOUNDATION
  SENIOR
  MASTER
}

enum SessionType {
  LIVE
  ASYNC
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum AsyncReadingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SenderType {
  USER
  READER
}

enum MessageType {
  TEXT
  READING_DRAFT
  READING_PUBLISHED
}

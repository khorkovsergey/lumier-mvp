generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Identity ──────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique
  passwordHash String?
  role         UserRole  @default(CLIENT)
  dateOfBirth  DateTime?
  balance      Float     @default(0)
  freeReadings Int       @default(2)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  questions      Question[]
  sessions       Session[]
  orders         Order[]
  readerProfile  TarotReader?
  articles       InsightArticle[]
  tarotReadings  TarotReadingRecord[]
  transactions   WalletTransaction[]
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float              // positive = top-up, negative = charge
  type      String             // topup, reading, refund
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum UserRole {
  CLIENT
  READER
  AUTHOR
  ADMIN
}

// ─── Reader profile ───────────────────────────────────────────────────────────

model TarotReader {
  id             String          @id @default(cuid())
  userId         String          @unique
  name           String
  specialization String
  tier           ReaderTier
  price          Float
  rating         Float           @default(5.0)
  bio            String
  imageUrl       String?
  isActive       Boolean         @default(true)
  approvalStatus ApprovalStatus  @default(PENDING)
  telegramChatId    String?   @unique
  telegramLinkToken  String?   @unique
  telegramLinkExpiry DateTime?
  phone          String?
  experience     String?         // years / description
  methods        String?         // comma-separated methods
  about          String?         // longer about text
  createdAt      DateTime        @default(now())

  user     User      @relation(fields: [userId], references: [id])
  sessions Session[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Question {
  id        String   @id @default(cuid())
  userId    String
  text      String
  category  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String        @id @default(cuid())
  userId    String
  readerId  String
  type      SessionType
  status    SessionStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  reader       TarotReader  @relation(fields: [readerId], references: [id])
  order        Order?
  asyncReading AsyncReading?
  messages     Message[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  sessionId String      @unique
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}

model AsyncReading {
  id          String             @id @default(cuid())
  sessionId   String             @unique
  status      AsyncReadingStatus @default(PENDING)
  resultText  String?
  draftText   String?
  createdAt   DateTime           @default(now())
  completedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id])
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  senderType SenderType
  content    String
  type       MessageType @default(TEXT)
  createdAt  DateTime    @default(now())

  session Session @relation(fields: [sessionId], references: [id])
}

model InsightArticle {
  id          String   @id @default(cuid())
  slug        String?  @unique
  title       String
  preview     String
  content     String
  category    String   @default("general")
  readTime    Int      @default(5)
  published   Boolean  @default(false)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// ─── Forecasts & Insights System ──────────────────────────────────────────────

model WeeklyInsight {
  id        String   @id @default(cuid())
  title     String
  content   String
  tone      String                // e.g. "напряжение", "рост", "перемены"
  weekStart DateTime
  published Boolean  @default(false)
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())
}

model GlobalForecast {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String                // politics, economy, technology, society
  published Boolean  @default(false)
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  eventDate   DateTime
  forecast    String?              // expandable forecast text
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BreakingInsight {
  id        String   @id @default(cuid())
  title     String
  content   String
  urgency   String   @default("medium") // low, medium, high
  published Boolean  @default(false)
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())
}

model AiForecast {
  id         String   @id @default(cuid())
  title      String
  prediction String
  basis      String              // what data it's based on
  published  Boolean  @default(false)
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())
}

model ForecastAccuracy {
  id          String   @id @default(cuid())
  prediction  String
  outcome     String
  accurate    Boolean
  category    String   @default("general")
  predictedAt DateTime
  resolvedAt  DateTime?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Reaction {
  id         String   @id @default(cuid())
  userId     String
  targetId   String              // ID of the item being reacted to
  targetType String              // weekly, global, breaking, ai
  type       String              // like, dislike
  createdAt  DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── AI Tarot Readings ────────────────────────────────────────────────────────

model TarotReadingRecord {
  id             String   @id @default(cuid())
  userId         String
  question       String
  category       String   @default("general")
  cardsJson      String   // JSON array of drawn cards
  summary        String
  interpretation String
  cardsInsight   String   // JSON array of per-card insights
  advice         String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReaderTier {
  FOUNDATION
  SENIOR
  MASTER
}

enum SessionType {
  LIVE
  ASYNC
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum AsyncReadingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SenderType {
  USER
  READER
}

enum MessageType {
  TEXT
  READING_DRAFT
  READING_PUBLISHED
}
